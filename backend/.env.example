# Copiá a .env para correr local (NUNCA commitees el .env real).
# En DigitalOcean App Platform estas van en el panel: Settings -> App-Level Environment Variables.

# Obligatoria. La API key de Claude (console.anthropic.com). Marcala como SECRET/encriptada en el panel.
ANTHROPIC_API_KEY=

# Opcionales (tienen default razonable):
# Modelo a usar. Default: claude-opus-4-8 (mejor calidad de copy). Alternativa mas economica: claude-sonnet-4-6
MODEL=claude-opus-4-8
# Origen del tablero permitido por CORS. Coma-separado para varios.
ALLOWED_ORIGIN=https://servifibras-web.github.io
# Tokens maximos de salida por descripcion.
MAX_TOKENS=4000
# Puerto. App Platform lo setea solo (8080); local podes usar 8080.
PORT=8080
